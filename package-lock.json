{
  "name": "olsera-mitra-modal",
  "version": "1.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "olsera-mitra-modal",
      "version": "1.0.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
      }
    },
    "apps/api": {
      "name": "@omm/api",
      "version": "1.0.0",
      "dependencies": {
        "@omm/shared": "*"
      }
    },
    "apps/web": {
      "name": "@omm/web",
      "version": "1.0.0",
      "dependencies": {
        "@omm/shared": "*"
      }
    },
    "node_modules/@omm/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@omm/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/@omm/ui": {
      "resolved": "packages/ui",
      "link": true
    },
    "node_modules/@omm/web": {
      "resolved": "apps/web",
      "link": true
    },
    "packages/shared": {
      "name": "@omm/shared",
      "version": "1.0.0"
    },
    "packages/ui": {
      "name": "@omm/ui",
      "version": "1.0.0",
      "dependencies": {
        "@omm/shared": "*"
      }
    }
  }
}
