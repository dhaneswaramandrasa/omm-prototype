# ============================================================
# Olsera Mitra Modal — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# --- Application ---
NODE_ENV=development
PORT=3001

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:3001/api/v1

# --- Database (MySQL 8) ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=omm_db
MYSQL_USER=omm_user
MYSQL_PASSWORD=omm_password
MYSQL_ROOT_PASSWORD=rootpassword

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispassword

# --- JWT ---
JWT_SECRET=change-me-to-a-random-256-bit-secret-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS ---
CORS_ORIGIN=http://localhost:5173

# --- Internal API Key (for cron jobs) ---
INTERNAL_API_KEY=change-me-to-a-random-secret
